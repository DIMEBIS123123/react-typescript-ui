{
	"compilerOptions": {
		"target": "es2022",
		"lib": ["ES2022"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"noEmit": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"verbatimModuleSyntax": true,
		"jsx": "react-jsx",
		"moduleDetection": "force",
		"types": []
	},
	"include": ["src"]
}
